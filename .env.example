# Template environment variables untuk Zig-Zag Barbershop Backend
# Salin file ini ke .env lalu isi nilai yang sesuai:
#   cp .env.example .env
#
# JANGAN commit file .env ke Git!

# ── Aplikasi ──────────────────────────────────────────────────────────────────
APP_NAME=Zig-Zag Barbershop
APP_ENV=development          # development | production
APP_PORT=8080

# ── Database (PostgreSQL / Supabase) ─────────────────────────────────────────
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=postgres
DB_SSLMODE=require           # disable | require | verify-full

# Connection string lengkap (digunakan oleh GORM).
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Gunakan string acak yang panjang dan unik. Minimal 32 karakter.
# Generate contoh: openssl rand -hex 32
JWT_SECRET=

# ── Google OAuth ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback