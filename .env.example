# Template environment variables untuk Zig-Zag Barbershop Backend
# Salin file ini ke .env lalu isi nilai yang sesuai:
#   cp .env.example .env
#
# JANGAN commit file .env ke Git!

# ── Aplikasi ──────────────────────────────────────────────────────────────────
APP_NAME=Zig-Zag Barbershop
APP_ENV=development          # development | production
PORT=8080
FRONTEND_URL=

# ── Database (PostgreSQL / Supabase) ─────────────────────────────────────────
# Connection string lengkap (digunakan oleh GORM).
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=

# ── Database Seeding ─────────────────────────────────────────────────────────
SEED_ADMIN_PASSWORD=
SEED_BARBER_PASSWORD=
SEED_CUSTOMER_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Gunakan string acak yang panjang dan unik. Minimal 32 karakter.
# Generate contoh: openssl rand -hex 32
JWT_SECRET=

# ── Google OAuth ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=